# ============================================================
# Environment Variables — Smart Document Auditor
# ============================================================
# INSTRUCTIONS:
# 1. Copy this file:   cp .env.example .env
# 2. Add your real key inside .env
# 3. NEVER commit .env to Git — it is in .gitignore
# ============================================================

# Get your free key from: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# ── LLM Provider Configuration ───────────────────────────────
# LLM_PROVIDER: "gemini" (cloud API) or "local" (OpenAI-compatible local endpoint like Ollama/LiteLLM)
LLM_PROVIDER=gemini
LOCAL_LLM_API_BASE=http://localhost:11434/v1
LOCAL_LLM_MODEL=gemini-2.0-flash-lite
LOCAL_LLM_API_KEY=dummy

# ── OPTIONAL (only if deploying to Google Cloud Run) ─────────
# You do NOT need this for local development or Docker.
# GOOGLE_CLOUD_PROJECT=your_gcp_project_id_here

