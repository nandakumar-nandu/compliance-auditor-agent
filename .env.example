# ============================================================
# Environment Variables — Smart Document Auditor
# ============================================================
# INSTRUCTIONS:
# 1. Copy this file:   cp .env.example .env
# 2. Add your real key inside .env
# 3. NEVER commit .env to Git — it is in .gitignore
# ============================================================

# ── OPTION A: Google Gemini Cloud API ──────────────────────────
# Uncomment this section if you want to use the cloud Gemini models.
LLM_PROVIDER=gemini
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash-lite

# ── OPTION B: Local LLM (Ollama/LiteLLM/offline) ───────────────
# Uncomment this section (and comment out Option A) for offline local execution.
# LLM_PROVIDER=local
# LOCAL_LLM_API_BASE=http://localhost:11434/v1
# LOCAL_LLM_MODEL=llama3
# LOCAL_LLM_API_KEY=dummy

# ── OPTIONAL (only if deploying to Google Cloud Run) ─────────
# You do NOT need this for local development or Docker.
# GOOGLE_CLOUD_PROJECT=your_gcp_project_id_here

